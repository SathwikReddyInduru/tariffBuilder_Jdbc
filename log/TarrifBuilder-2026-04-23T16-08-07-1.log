<html>
<head>
    <title>Xius Login</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="icon" type="image/jpeg" href="/images/favicon.jpeg">
    <link rel="stylesheet" href="/css/builder.css">
</head>
 
<body class="login-body">
     
     
    <div class="login-shell">
        <div class="login-left">
            <div class="left-overlay"></div>
            <div class="left-content">
                <!-- <img th:src="@{/images/logo.png}" alt="Xius Logo" class="panel-logo"> -->
                <img src="/images/tariff.png" class="tariff-img" alt="Tariff Builder">
               
            </div>
        </div>
 
        <div class="login-right">
            <div class="login-form-card">
                <div class="login-heading">
                   
                    <h1>Login</h1>
                    <p>Enter your credentials to access the system</p>
                </div>
 
                <div class="error-message">Please enter Network Name</div>
 
                <form action="/login" method="post" autocomplete="off">
                    <div class="input-box">
                        <label>Network *</label>
                        <div class="input-wrapper">
                            <input type="text" placeholder="Enter network name" id="networkLoginName" name="networkLoginName" value="">
                            <span class="material-icons">dns</span>
                        </div>
                    </div>
 
                    <div class="input-box">
                       <label>Username *</label>
                        <div class="input-wrapper">
                            <input type="text" placeholder="Enter username" id="loginId" name="loginId" value="">
                            <span class="material-icons">person</span>
                        </div>
                    </div>
 
                    <div class="input-box">
                        <label>Password *</label>
                        <div class="input-wrapper">
                            <input type="password" placeholder="Enter password" id="password" name="password" value="">
                            <span class="material-icons">lock</span>
                        </div>
                    </div>
 
                    <div class="login-buttons">
                        <button type="reset" class="btn-cancel">Cancel</button>
                        <button type="submit" class="btn-submit">Submit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
 
</body>
</html>
 
